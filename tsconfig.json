{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "app-expo-backup",
    "components-expo-backup",
    "src/components-navigation-backup",
    "src/components-screens-backup",
    "src/components-ui-backup",
    "src-theme-backup",
    "src-providers-backup",
    "src-hooks-backup",
    "src/features/comercios",
    "src/features/feed",
    "src/features/feira",
    "src/features/interaja",
    "src/features/mapa",
    "src/features/notificacoes",
    "src/features/programacao",
    "src/features/home/components-expo-backup",
    "src/features/home/hooks-expo-backup",
    "src/features/home/icons-expo-backup",
    "src/features/home/theme-expo-backup",
    "src/features/search",
    "src/features/vantagens",
    "playwright.config.ts",
    "tamagui.config.ts",
    "tamagui.build.ts",
    "tests",
    "src/features/home/data"
  ]
}
